// Syncthing ignore patterns for cross-platform development.
// These directories contain platform-specific build artifacts
// that must NOT be synced between Windows and Linux.
// Each platform rebuilds them locally (npm install, cargo build).

// Rust build artifacts (platform-specific binaries, ~1-2 GB)
src-tauri/target

// Node.js dependencies (platform-specific native modules)
node_modules

// Frontend build output (rebuilt by Vite)
dist
dist-ssr

// Syncthing temporary/conflict files (cleanup)
*.sync-conflict-*
~syncthing~*
