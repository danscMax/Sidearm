{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidearm",
  "version": "0.1.5",
  "identifier": "com.sidearm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:45173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sidearm",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false,
        "decorations": false,
        "visible": false,
        "backgroundColor": [26, 31, 22, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/sidearm-ca.cer",
      "resources/presets/*.json"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./nsis-hooks.nsh"
      }
    }
  }
}
